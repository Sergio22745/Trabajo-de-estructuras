class Nodo:
    """Nodo de la lista circular. Almacena un jugador."""
    def __init__(self, dato):
        self.dato = dato   # dato es un diccionario con info del jugador
        self.sig = None


class ListaCircular:
    """Lista circular simplemente enlazada para gestionar jugadores."""

    def __init__(self):
        self.cabeza = None
        self.total_nodos = 0

    # ── Insertar al final ──────────────────────────────────
    def insertar(self, dato):
        nuevo = Nodo(dato)
        if self.cabeza is None:
            self.cabeza = nuevo
            nuevo.sig = self.cabeza
        else:
            temp = self.cabeza
            while temp.sig != self.cabeza:
                temp = temp.sig
            temp.sig = nuevo
            nuevo.sig = self.cabeza
        self.total_nodos += 1

    # ── Mostrar todos los jugadores ────────────────────────
    def mostrar(self):
        if not self.cabeza:
            print("  (Lista vacía)")
            return
        temp = self.cabeza
        print(f"  {'Nombre':<15} {'Estado':<10} {'Turnos'}")
        print("  " + "-" * 35)
        while True:
            j = temp.dato
            estado = "Activo" if j["activo"] else "Pausado"
            print(f"  {j['nombre']:<15} {estado:<10} {j['turnos']}")
            temp = temp.sig
            if temp == self.cabeza:
                break

    # ── Buscar jugador por nombre ──────────────────────────
    def buscar(self, nombre):
        if not self.cabeza:
            return None
        temp = self.cabeza
        while True:
            if temp.dato["nombre"].lower() == nombre.lower():
                return temp
            temp = temp.sig
            if temp == self.cabeza:
                break
        return None

    # ── Eliminar jugador ───────────────────────────────────
    def eliminar(self, nombre):
        if not self.cabeza:
            print("  Lista vacía, no hay jugadores que eliminar.")
            return False

        # Caso: un solo nodo
        if self.cabeza.sig == self.cabeza:
            if self.cabeza.dato["nombre"].lower() == nombre.lower():
                self.cabeza = None
                self.total_nodos -= 1
                return True
            return False

        # Buscar el nodo y su anterior
        prev = None
        temp = self.cabeza
        while True:
            if temp.dato["nombre"].lower() == nombre.lower():
                break
            prev = temp
            temp = temp.sig
            if temp == self.cabeza:
                return False   # No encontrado

        # Eliminar la cabeza
        if temp == self.cabeza:
            # Ir al último para actualizar su .sig
            ultimo = self.cabeza
            while ultimo.sig != self.cabeza:
                ultimo = ultimo.sig
            self.cabeza = self.cabeza.sig
            ultimo.sig = self.cabeza
        else:
            prev.sig = temp.sig

        self.total_nodos -= 1
        return True

    # ── Pausar / reactivar ─────────────────────────────────
    def cambiar_estado(self, nombre, pausar=True):
        nodo = self.buscar(nombre)
        if nodo:
            nodo.dato["activo"] = not pausar
            return True
        return False

    # ── Contar activos / pausados ──────────────────────────
    def contar_activos(self):
        if not self.cabeza:
            return 0
        cuenta = 0
        temp = self.cabeza
        while True:
            if temp.dato["activo"]:
                cuenta += 1
            temp = temp.sig
            if temp == self.cabeza:
                break
        return cuenta

    # ── Jugador con más turnos ─────────────────────────────
    def jugador_mas_turnos(self):
        if not self.cabeza:
            return None
        temp = self.cabeza
        lider = temp.dato
        while True:
            if temp.dato["turnos"] > lider["turnos"]:
                lider = temp.dato
            temp = temp.sig
            if temp == self.cabeza:
                break
        return lider

    # ── Verificar si queda solo un activo ──────────────────
    def unico_activo(self):
        activos = []
        if not self.cabeza:
            return None
        temp = self.cabeza
        while True:
            if temp.dato["activo"]:
                activos.append(temp.dato)
            temp = temp.sig
            if temp == self.cabeza:
                break
        return activos[0] if len(activos) == 1 else None


