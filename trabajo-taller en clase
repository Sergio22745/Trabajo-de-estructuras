def separador(titulo=""):
    ancho = 45
    if titulo:
        print("\n" + "=" * ancho)
        print(f"  {titulo}")
        print("=" * ancho)
    else:
        print("-" * ancho)


def crear_jugador(nombre):
    return {"nombre": nombre, "activo": True, "turnos": 0}


def registrar_jugadores(lista):
    separador("1. REGISTRO DE JUGADORES")
    print("  Ingrese mínimo 6 jugadores.")
    print("  Escriba 'listo' cuando termine (después del mínimo).\n")

    while True:
        nombre = input(f"  Jugador #{lista.total_nodos + 1}: ").strip()

        if nombre.lower() == "listo":
            if lista.total_nodos < 6:
                faltantes = 6 - lista.total_nodos
                print(f"  ⚠ Faltan {faltantes} jugador(es). Debe registrar al menos 6.")
            else:
                print(f"\n  ✔ Registro completado con {lista.total_nodos} jugadores.")
                break
        elif nombre == "":
            print("  ⚠ El nombre no puede estar vacío.")
        elif lista.buscar(nombre):
            print(f"  ⚠ '{nombre}' ya está registrado. Use un nombre diferente.")
        else:
            lista.insertar(crear_jugador(nombre))
            print(f"  ✔ {nombre} registrado.")
            if lista.total_nodos == 6:
                print("  (Mínimo alcanzado. Puede seguir agregando o escribir 'listo')")


def mostrar_jugadores(lista):
    separador("2. JUGADORES REGISTRADOS")
    lista.mostrar()


def buscar_jugador(lista):
    separador("3. BUSCAR JUGADOR")
    nombre = input("  Ingrese el nombre a buscar: ").strip()
    nodo = lista.buscar(nombre)
    if nodo:
        j = nodo.dato
        estado = "Activo" if j["activo"] else "Pausado"
        print(f"  ✔ Jugador encontrado: {j['nombre']} | Estado: {estado} | Turnos: {j['turnos']}")
    else:
        print(f"  ✘ Jugador no encontrado: '{nombre}'")


def eliminar_jugador(lista):
    separador("4. ELIMINAR JUGADOR")
    nombre = input("  Ingrese el nombre a eliminar: ").strip()
    if lista.eliminar(nombre):
        print(f"  ✔ '{nombre}' eliminado correctamente.")
        print("\n  Lista actualizada:")
        lista.mostrar()
    else:
        print(f"  ✘ No se encontró '{nombre}' en la lista.")


def pausar_reactivar(lista):
    separador("5. PAUSAR / REACTIVAR JUGADOR")
    nombre = input("  Nombre del jugador: ").strip()
    nodo = lista.buscar(nombre)
    if not nodo:
        print(f"  ✘ Jugador '{nombre}' no encontrado.")
        return
    estado_actual = "Activo" if nodo.dato["activo"] else "Pausado"
    print(f"  Estado actual de {nombre}: {estado_actual}")
    accion = input("  ¿Pausar (p) o Reactivar (r)? ").strip().lower()
    if accion == "p":
        lista.cambiar_estado(nombre, pausar=True)
        print(f"  ✔ {nombre} pausado.")
    elif accion == "r":
        lista.cambiar_estado(nombre, pausar=False)
        print(f"  ✔ {nombre} reactivado.")
    else:
        print("  Opción no válida.")


def simular_turnos(lista, num_turnos=10):
    separador("6. SIMULACIÓN DE TURNOS AUTOMÁTICOS")
    if lista.contar_activos() == 0:
        print("  No hay jugadores activos para simular.")
        return

    print(f"  Simulando {num_turnos} turnos...\n")

    # Puntero circular: empieza en cabeza
    actual = lista.cabeza
    turnos_realizados = 0

    while turnos_realizados < num_turnos:
        # Verificar ganador antes de cada turno
        ganador = lista.unico_activo()
        if ganador:
            print(f"\n  ¡Solo queda un jugador activo!")
            break

        # Saltar jugadores pausados
        if not actual.dato["activo"]:
            actual = actual.sig
            continue

        actual.dato["turnos"] += 1
        turnos_realizados += 1
        print(f"  Turno {turnos_realizados:>3}: 🎮 {actual.dato['nombre']} "
              f"(turno #{actual.dato['turnos']})")
        actual = actual.sig

    print(f"\n  Total de turnos simulados: {turnos_realizados}")


def mostrar_estadisticas(lista):
    separador("7. ESTADÍSTICAS DEL TORNEO")
    total = lista.total_nodos
    activos = lista.contar_activos()
    pausados = total - activos
    lider = lista.jugador_mas_turnos()

    print(f"  Total de jugadores  : {total}")
    print(f"  Jugadores activos   : {activos}")
    print(f"  Jugadores pausados  : {pausados}")
    if lider:
        print(f"  Jugador con más turnos: {lider['nombre']} ({lider['turnos']} turnos)")
    else:
        print("  Sin datos de turnos aún.")


def detectar_ganador(lista):
    separador("8. GANADOR FINAL")
    ganador = lista.unico_activo()
    if ganador:
        print()
        print("  ╔══════════════════════════════════════╗")
        print("  ║      🏆 GANADOR DEL TORNEO 🏆        ║")
        print(f"  ║        {ganador['nombre']:^30}  ║")
        print(f"  ║     Turnos jugados: {ganador['turnos']:<17}║")
        print("  ╚══════════════════════════════════════╝")
    else:
        activos = lista.contar_activos()
        if activos == 0:
            print("  No quedan jugadores activos.")
        else:
            print(f"  Aún hay {activos} jugadores activos. El torneo continúa.")


