        print("  4. Eliminar jugador")
        print("  5. Pausar / Reactivar jugador")
        print("  6. Simular turnos automáticos")
        print("  7. Mostrar estadísticas")
        print("  8. Detectar ganador final")
        print("  0. Salir")
        separador()

        opcion = input("  Seleccione una opción: ").strip()

        if opcion == "1":
            registrar_jugadores(lista)
